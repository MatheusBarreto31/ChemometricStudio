{
  "display_name": "Centralizar e Normalizar",
  "category": "Pré-Processamento",
  "data_type": "all",
  "input_aliases": {
    "X_cal": "X Calibração",
    "X_val": "X Validação",
    "center": "Centralizar",
    "normalize": "Normalizar",
    "nway_flag": "Dimensionalidade",
    "direction": "Direção"
  },
  "output_aliases": {
    "X_cal": "X Cal (Processado)",
    "X_val": "X Val (Processado)"
  },
  "output_synonyms": {
    "X_cal": ["X", "X_train"],
    "X_val": ["X_test", "X_validation"]
  },
  "short_description": "Centraliza e/ou normaliza dados espectroscópicos",
  "long_description": "Etapa de pré-processamento que centraliza e/ou normaliza dados para melhorar o desempenho do modelo. Preparação essencial para métodos de calibração multivariada.\n\nCentralização:\n- Subtrai as médias das colunas de todas as amostras\n- Remove efeitos de linha de base/deslocamento\n- Centraliza dados em torno de zero\n- Recomendado para a maioria das aplicações\n\nNormalização (Autoscaling):\n- Divide pelos desvios padrão das colunas\n- Dimensiona cada variável para variância unitária\n- Dá peso igual a todas as variáveis\n- Importante quando variáveis têm escalas/unidades diferentes\n- Particularmente útil para dados espectroscópicos\n\nEfeitos de Combinação:\n\nApenas Centralização:\n- Remove diferenças de deslocamento entre amostras\n- Preserva estrutura de variância\n- Bom quando variáveis estão na mesma escala\n\nApenas Normalização (raro):\n- Sem centralização, menos comum\n- Útil para distribuições de dados específicas\n\nTanto Centralização + Normalização (recomendado):\n- Pré-processamento padrão para quimiometria\n- Tratamento igual de todas as variáveis\n- Melhora estabilidade e interpretabilidade do modelo\n- Necessário para a maioria das aplicações PLS e PCR\n\nDados Multidirecionais:\n- Funciona com dados 2D, 3D e de dimensões superiores\n- Parâmetro de direção especifica o eixo\n- Direção padrão (-1) se aplica ao longo do último eixo\n\nNota: Dados de validação serão transformados usando estatísticas de calibração durante a modelagem.",
  "setup": {
    "layout": [
      {
        "name": "center",
        "label": "Centralizar Dados",
        "widget": "checkbutton",
        "default": true,
        "required": true,
        "input_type": "user",
        "tooltip": "Subtrair médias das colunas (centralização/mean-centering)"
      },
      {
        "name": "normalize",
        "label": "Normalizar Dados",
        "widget": "checkbutton",
        "default": false,
        "required": true,
        "input_type": "user",
        "tooltip": "Dimensionar para variância unitária (autoscaling)"
      },
      {
        "name": "direction",
        "label": "Direção (para multidirecionais, -1=padrão)",
        "widget": "entry",
        "type": "int",
        "default": "-1",
        "required": false,
        "input_type": "user",
        "tooltip": "Dimensão ao longo da qual centralizar/normalizar (-1 para padrão)"
      },
      {
        "name": "X_cal",
        "label": "Dados X Calibração",
        "widget": "data_input",
        "required": true,
        "input_type": "routed",
        "visible_if": {"input_type": "user"},
        "tooltip": "Roteado da saída da função anterior"
      },
      {
        "name": "X_val",
        "label": "Dados X Validação",
        "widget": "data_input",
        "required": false,
        "input_type": "routed",
        "visible_if": {"input_type": "user"},
        "tooltip": "Roteado da saída da função anterior"
      },
      {
        "name": "nway_flag",
        "label": "Dimensionalidade dos Dados",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": true,
        "input_type": "inherited",
        "visible_if": {"input_type": "user"},
        "tooltip": "Automaticamente herdada da função Carregar Dados"
      }
    ]
  },
