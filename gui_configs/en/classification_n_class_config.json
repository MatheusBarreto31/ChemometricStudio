    "logistic_max_iter": "Logistic Max Iterations",
    "random_forest_n_estimators": "RF Trees",
    "random_forest_max_depth": "RF Max Depth",
    "random_forest_min_samples_leaf": "RF Min Samples Leaf",
    "extra_trees_n_estimators": "ET Trees",
    "extra_trees_max_depth": "ET Max Depth",
    "extra_trees_min_samples_leaf": "ET Min Samples Leaf",
    "svc_c": "SVC C",
    "svc_gamma": "SVC Gamma",
    "svc_kernel": "SVC Kernel",
    "knn_n_neighbors": "KNN Neighbors",
