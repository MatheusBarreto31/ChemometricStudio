{
  "display_name": "PARAFAC Analysis",
  "category": "4.Dimensionality Reduction",
  "data_type": "multiway",
  "input_aliases": {
    "X_cal": "X Calibration",
    "Y_cal": "Y Calibration",
    "X_val": "X Validation",
    "Y_val": "Y Validation",
    "n_components": "Components",
    "nway_flag": "Data Order",
    "mode_centering": "Mode Centering",
    "mode_normalization": "Mode Normalization",
    "constraint_non_negative": "Non-negative Constraint",
    "constraint_l1_reg": "L1 Regularization Constraint",
    "constraint_l2_reg": "L2 Regularization Constraint",
    "constraint_l2_square_reg": "L2 Squared Regularization Constraint",
    "constraint_unimodality": "Unimodality Constraint",
    "constraint_normalize": "Normalize Constraint",
    "constraint_simplex": "Simplex Constraint",
    "constraint_normalized_sparsity": "Normalized Sparsity Constraint",
    "constraint_soft_sparsity": "Soft Sparsity Constraint",
    "constraint_smoothness": "Smoothness Constraint",
    "constraint_monotonicity": "Monotonicity Constraint",
    "constraint_hard_sparsity": "Hard Sparsity Constraint",
    "unconstrained_sparsity": "Sparsity (Unconstrained Only)",
    "unconstrained_linesearch": "Linesearch (Unconstrained Only)",
    "unconstrained_orthogonalise": "Orthogonalise (Unconstrained Only)",
    "init_method": "Initialization",
    "random_multi_start": "Random Multi-Start",
    "random_multi_start_runs": "Random Multi-Start Runs",
    "max_iter": "Max Iterations",
    "tol": "Tolerance",
    "random_state": "Random Seed",
    "missing_constrained_solver": "Missing+Constraint Solver",
    "orient_mostly_negative_pairs": "Orient Mostly-Negative Mode Pairs",
    "profile_paths": "Profile Files",
    "profile_usage": "Profile Usage",
    "sweep_mode": "Sweep Mode",
    "component_range": "Component Range",
    "component_y_mapping": "Component-Y Mapping",
    "cv_config": "CV Configuration",
    "axis_n_info": "Axis Vectors",
    "dim_labels": "Dimension Labels"
  },
  "output_aliases": {
    "scores_mode_a": "Scores (Mode A)",
    "val_scores_mode_a": "Validation Scores (Mode A)",
    "scores_mode_a_heatmap": "Scores (Mode A Heatmap Matrix)",
    "mode_a_sample_axis": "Mode A Sample Axis",
    "mode_a_component_axis": "Mode A Component Axis",
    "sweep_F": "Sweep Components (F)",
    "sweep_sfit": "Sweep sfit",
    "sweep_core_consistency": "Sweep Core Consistency",
    "sweep_explained_variance": "Sweep Explained Variance",
    "sweep_n_iter": "Sweep Iterations",
    "factors": "Factors",
    "weights": "Weights",
    "instrumental_profiles": "Instrumental Profiles",
    "reconstructed": "Reconstructed Tensor",
    "residual": "Residual Tensor",
    "metrics": "Metrics",
    "calibration_models": "Calibration Models",
    "component_y_mapping": "Component-Y Pairing",
    "reference_angles": "Reference Angles",
    "parafac_report": "PARAFAC Report",
    "sweep_results": "Sweep Results",
    "selected_n_components": "Selected Components",
    "cv_results": "CV Results",
    "y_cv_pred": "CV Predictions"
  },
  "short_description": "PARAFAC decomposition with missing-data, profile constraints, sweep, calibration, and CV support.",
  "long_description": "Fits a CP/PARAFAC model to multiway data, supports NaN-aware fitting, optional reference/initial/fixed profiles, optional sweep across component counts, and calibration of mode-A scores against Y.",
  "setup": {
    "categories": [
      "Model Parameters",
      "Data Inputs",
      "Per-Mode Options",
      "Constraints",
      "Unconstrained Model Options",
      "Profiles",
      "Calibration",
      "Cross-Validation"
    ],
    "layout": [
      {
        "name": "n_components",
        "label": "Number of Components",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "2",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "init_method",
        "label": "Initialization",
        "category": "Model Parameters",
        "widget": "combobox",
        "values": ["svd", "random", "custom"],
        "value_aliases": ["SVD", "Random", "Custom"],
        "default": "svd",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "max_iter",
        "label": "Maximum Iterations",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "500",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "random_multi_start",
        "label": "Random Multi-Start",
        "category": "Model Parameters",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "visible_if": {
          "init_method": "random"
        },
        "tooltip": "When enabled, run multiple random initializations and keep the best fit."
      },
      {
        "name": "random_multi_start_runs",
        "label": "Random Multi-Start Runs",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "5",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "init_method": "random",
          "random_multi_start": true
        },
        "tooltip": "Number of random starts when multi-start is enabled. Minimum is 1."
      },
      {
        "name": "tol",
        "label": "Tolerance",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "float",
        "default": "1e-7",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "random_state",
        "label": "Random Seed",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Optional integer seed. Leave blank for different random results on each run."
      },
      {
        "name": "missing_constrained_solver",
        "label": "Missing+Constraint Solver",
        "category": "Model Parameters",
        "widget": "combobox",
        "values": ["em", "em_adaptive", "weighted_ao_admm"],
        "value_aliases": ["EM", "EM Adaptive", "Weighted AO-ADMM"],
        "default": "em",
        "required": false,
        "input_type": "user",
        "tooltip": "Used only when both missing values and TensorLy constraints are active."
      },
      {
        "name": "orient_mostly_negative_pairs",
        "label": "Orient Mostly-Negative Mode Pairs",
        "category": "Model Parameters",
        "widget": "checkbutton",
        "default": true,
        "required": false,
        "input_type": "user",
        "tooltip": "If enabled, components are sign-oriented by flipping pairs of mostly-negative mode vectors before score extraction. This improves interpretability without changing the fitted tensor."
      },
      {
        "name": "sweep_mode",
        "label": "Sweep Components",
        "category": "Model Parameters",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user"
      },
      {
        "name": "component_range",
        "label": "Component Range",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "sweep_mode": true
        },
        "tooltip": "Examples: 2:6, 2-8, 2,3,4,5"
      },
      {
        "name": "mode_centering",
        "label": "Mode Centering",
        "category": "Per-Mode Options",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enable centering for selected modes. One checkbutton per mode, including sample mode."
      },
      {
        "name": "mode_normalization",
        "label": "Mode Normalization",
        "category": "Per-Mode Options",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enable normalization for selected modes. One checkbutton per mode, including sample mode."
      },
      {
        "name": "constraint_non_negative",
        "label": "Non-negative",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies non-negativity to selected modes. One checkbutton per mode, including sample mode."
      },
      {
        "name": "constraint_l1_reg",
        "label": "L1 Regularization",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies L1 regularization to selected modes (fixed strength)."
      },
      {
        "name": "constraint_l2_reg",
        "label": "L2 Regularization",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies L2 regularization to selected modes (fixed strength)."
      },
      {
        "name": "constraint_l2_square_reg",
        "label": "L2 Squared Regularization",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies squared L2 regularization to selected modes (fixed strength)."
      },
      {
        "name": "constraint_unimodality",
        "label": "Unimodality",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enforces unimodal factors for selected modes."
      },
      {
        "name": "constraint_normalize",
        "label": "Normalize",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enables TensorLy normalize constraint for selected modes."
      },
      {
        "name": "constraint_simplex",
        "label": "Simplex",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies simplex constraint to selected modes (fixed strength)."
      },
      {
        "name": "constraint_normalized_sparsity",
        "label": "Normalized Sparsity",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies normalized sparsity to selected modes (fixed strength)."
      },
      {
        "name": "constraint_soft_sparsity",
        "label": "Soft Sparsity",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies soft sparsity to selected modes (fixed strength)."
      },
      {
        "name": "constraint_smoothness",
        "label": "Smoothness",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies smoothness constraint to selected modes (fixed strength)."
      },
      {
        "name": "constraint_monotonicity",
        "label": "Monotonicity",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enforces monotonic factors for selected modes."
      },
      {
        "name": "constraint_hard_sparsity",
        "label": "Hard Sparsity",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "nway_flag",
        "count_offset": 1,
        "item_label_prefix": "Mode",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Applies hard sparsity to selected modes (fixed strength)."
      },
      {
        "name": "unconstrained_sparsity",
        "label": "Sparsity",
        "category": "Unconstrained Model Options",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Unconstrained PARAFAC only. Global model-level option (not per-mode). Ignored when any mode constraints are enabled."
      },
      {
        "name": "unconstrained_linesearch",
        "label": "Linesearch",
        "category": "Unconstrained Model Options",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Unconstrained PARAFAC only. Global model-level option (not per-mode). Ignored when any mode constraints are enabled."
      },
      {
        "name": "unconstrained_orthogonalise",
        "label": "Orthogonalise",
        "category": "Unconstrained Model Options",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Unconstrained PARAFAC only. Global model-level option (not per-mode). Ignored when any mode constraints are enabled."
      },
      {
        "name": "profile_paths",
        "label": "Profile Files",
        "category": "Profiles",
        "widget": "file_selector_list",
        "count_source": "nway_flag",
        "required": false,
        "input_type": "user",
        "tooltip": "List of profile files (one per data mode, based on Data Order)."
      },
      {
        "name": "profile_usage",
        "label": "Profile Usage",
        "category": "Profiles",
        "widget": "combobox_list",
        "count_source": "nway_flag",
        "values": ["none", "reference", "initial", "fixed"],
        "value_aliases": ["None", "Reference", "Initial", "Fixed"],
        "default": "none",
        "required": false,
        "input_type": "user",
        "tooltip": "Usage mode per profile input: none, reference, initial, or fixed."
      },
      {
        "name": "component_y_mapping",
        "label": "Component to Y Mapping",
        "category": "Calibration",
        "widget": "entry_list",
        "count_source": "n_components",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "One entry per component: Y column index (1-based). Empty entry excludes that component. If all are empty, all valid component-to-Y combinations are evaluated automatically."
      },
      {
        "name": "X_cal",
        "label": "X Calibration Data",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": true,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      },
      {
        "name": "Y_cal",
        "label": "Y Calibration Data",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      },
      {
        "name": "X_val",
        "label": "X Validation Data",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      },
      {
        "name": "Y_val",
        "label": "Y Validation Data",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      },
      {
        "name": "nway_flag",
        "label": "Data Order",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "inherited"
      },
      {
        "name": "axis_n_info",
        "label": "Axis Vectors",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      },
      {
        "name": "dim_labels",
        "label": "Dimension Labels",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      },
      {
        "name": "cv_config",
        "label": "CV Configuration",
        "category": "Cross-Validation",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "routed"
      }
    ]
  },
  "analysis": {
    "pages": [
      {
        "title": "PARAFAC Report",
        "layout": "fp",
        "sections": [
          {
            "type": "text",
            "config": {
              "title": "PARAFAC Text Report",
              "text_template": "{report_text}",
              "bindings": [
                {
                  "name": "report_text",
                  "data_source": "parafac_report",
                  "selector": {
                    "mode": "value"
                  }
                }
              ]
            }
          }
        ]
      },
      {
        "title": "Sweep Scree",
        "layout": "fd",
        "condition": {
          "parameter": "sweep_mode",
          "operator": "==",
          "value": "True"
        },
        "sections": [
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "marker": "o",
              "x_axis": {
                "data_source": "sweep_F",
                "force_integer": true,
                "label": "F"
              },
              "y_axis": {
                "data_source": "sweep_sfit",
                "label": "sfit"
              },
              "title": "Sweep: sfit vs F",
              "show_origin": false
            }
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "marker": "o",
              "x_axis": {
                "data_source": "sweep_F",
                "force_integer": true,
                "label": "F"
              },
              "y_axis": {
                "data_source": "sweep_core_consistency",
                "label": "Core Consistency"
              },
              "title": "Sweep: Core Consistency vs F",
              "show_origin": false
            }
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "marker": "o",
              "x_axis": {
                "data_source": "sweep_F",
                "force_integer": true,
                "label": "F"
              },
              "y_axis": {
                "data_source": "sweep_explained_variance",
                "label": "Explained Variance (%)"
              },
              "title": "Sweep: Explained Variance vs F",
              "show_origin": false
            }
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "marker": "o",
              "x_axis": {
                "data_source": "sweep_F",
                "force_integer": true,
                "label": "F"
              },
              "y_axis": {
                "data_source": "sweep_n_iter",
                "label": "Iterations"
              },
              "title": "Sweep: Iterations vs F",
              "show_origin": false
            }
          }
        ]
      },
      {
        "title": "Mode A Scores",
        "layout": "ew",
        "sections": [
          {
            "type": "graph",
            "config": {
              "graph_type": "scatter",
              "title": "Mode A Scores vs Y Reference",
              "show_origin": true,
              "datasets": [
                {
                  "x_axis": {
                    "data_source": "Y_cal",
                    "axis_type": "linear",
                    "label": "Y Reference"
                  },
                  "y_axis": {
                    "data_source": "scores_mode_a",
                    "axis_type": "linear",
                    "label": "Mode A Score"
                  },
                  "label": "Calibration"
                },
                {
                  "x_axis": {
                    "data_source": "Y_val",
                    "axis_type": "linear",
                    "label": "Y Reference"
                  },
                  "y_axis": {
                    "data_source": "val_scores_mode_a",
                    "axis_type": "linear",
                    "label": "Mode A Score"
                  },
                  "label": "Validation"
                }
              ],
              "data_slicing": [
                {
                  "name": "Y Column",
                  "dimension": 1,
                  "axis": "x",
                  "default": 0,
                  "show_navigation_menu": true
                },
                {
                  "name": "Component",
                  "dimension": 1,
                  "axis": "y",
                  "default": 0,
                  "show_navigation_menu": true
                }
              ]
            }
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "heatmap",
              "flip_xy": true,
              "y_axis": {
                "data_source": "mode_a_component_axis",
                "force_integer": true,
                "label": "Component"
              },
              "x_axis": {
                "data_source": "mode_a_sample_axis",
                "force_integer": true,
                "reverse_axis": true,
                "label": "Sample"
              },
              "z_axis": {
                "data_source": "scores_mode_a_heatmap",
                "label": "Mode A Score"
              },
              "title": "Mode A Scores Heatmap (Samples x Components)"
            }
          }
        ]
      },
      {
        "title": "Instrumental Profiles",
        "layout": "ew",
        "sections": [
          {
            "type": "graph",
            "config": {
              "graph_type": "heatmap",
              "aux_axis": {
                "data_source": "axis_n_info",
                "labels": "dim_labels"
              },
              "x_axis": {
                "data_source": "axis_n_info",
                "index": 2,
                "label": "dim_labels",
                "l_index": 2
              },
              "y_axis": {
                "data_source": "axis_n_info",
                "index": 1,
                "label": "dim_labels",
                "l_index": 1
              },
              "z_axis": {
                "data_source": "instrumental_profiles",
                "label": "Contribution"
              },
              "title": "Instrumental Profiles by Component",
              "dimension_labels": "dim_labels",
              "data_slicing": [
                {
                  "name": "Component",
                  "dimension": 0,
                  "default": 0,
                  "axis": "z",
                  "show_navigation_menu": true
                }
              ],
              "show_md_menu": true
            }
          }
        ]
      }
    ],
    "current_page": 0
  }
}
