{
  "display_name": "Center & Normalize",
  "category": "Preprocessing",
  "data_type": "all",
  "input_aliases": {
    "X_cal": "X Calibration",
    "X_val": "X Validation",
    "center": "Center",
    "normalize": "Normalize",
    "nway_flag": "Dimensionality",
    "direction": "Direction"
