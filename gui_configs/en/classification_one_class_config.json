  "analysis": {
    "pages": [
      {
        "title": "Performance Summary",
        "layout": "ew",
        "sections": [
          {
            "type": "text",
            "config": {
              "title": "Performance Report",
              "text_template": "One-Class Classification Performance Report\n===========================================\nMethod:                {method}\nReference Class:       {ref_class}\nNon-Reference Label:   {unknown_label}\nFit Samples:           {fit_n}\n\nCalibration\n-----------\nSamples:               {n_cal}\nTrue Positives (TP):   {tp_cal}\nTrue Negatives (TN):   {tn_cal}\nFalse Positives (FP):  {fp_cal}\nFalse Negatives (FN):  {fn_cal}\nAccuracy:              {acc_cal}\nF1 (Macro):            {f1_cal}\nPrecision (Macro):     {prec_cal}\nRecall (Macro):        {rec_cal}\nInlier Rate:           {inlier_cal}\n\nValidation\n----------\nSamples:               {n_val}\nTrue Positives (TP):   {tp_val}\nTrue Negatives (TN):   {tn_val}\nFalse Positives (FP):  {fp_val}\nFalse Negatives (FN):  {fn_val}\nAccuracy:              {acc_val}\nF1 (Macro):            {f1_val}\nPrecision (Macro):     {prec_val}\nRecall (Macro):        {rec_val}\nInlier Rate:           {inlier_val}",
              "bindings": [
                {
                  "name": "method",
                  "data_source": "model",
                  "nested_key": "model_type",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "ref_class",
                  "data_source": "model",
                  "nested_key": "reference_class",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "unknown_label",
                  "data_source": "model",
                  "nested_key": "class_labels",
                  "selector": {
                    "mode": "index",
                    "index": 0
                  }
                },
                {
                  "name": "fit_n",
                  "data_source": "model",
                  "nested_key": "fit_sample_count",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "n_cal",
                  "data_source": "metrics",
                  "nested_key": "calibration.n_samples",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "tp_cal",
                  "data_source": "confusion_matrices",
                  "nested_key": "calibration.matrix.1.1",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "tn_cal",
                  "data_source": "confusion_matrices",
                  "nested_key": "calibration.matrix.0.0",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "fp_cal",
                  "data_source": "confusion_matrices",
                  "nested_key": "calibration.matrix.0.1",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "fn_cal",
                  "data_source": "confusion_matrices",
                  "nested_key": "calibration.matrix.1.0",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "acc_cal",
                  "data_source": "metrics",
                  "nested_key": "calibration.accuracy",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "f1_cal",
                  "data_source": "metrics",
                  "nested_key": "calibration.f1_macro",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "prec_cal",
                  "data_source": "metrics",
                  "nested_key": "calibration.precision_macro",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "rec_cal",
                  "data_source": "metrics",
                  "nested_key": "calibration.recall_macro",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "inlier_cal",
                  "data_source": "metrics",
                  "nested_key": "one_class.inlier_rate_calibration",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "n_val",
                  "data_source": "metrics",
                  "nested_key": "validation.n_samples",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "tp_val",
                  "data_source": "confusion_matrices",
                  "nested_key": "validation.matrix.1.1",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "tn_val",
                  "data_source": "confusion_matrices",
                  "nested_key": "validation.matrix.0.0",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "fp_val",
                  "data_source": "confusion_matrices",
                  "nested_key": "validation.matrix.0.1",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "fn_val",
                  "data_source": "confusion_matrices",
                  "nested_key": "validation.matrix.1.0",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "acc_val",
                  "data_source": "metrics",
                  "nested_key": "validation.accuracy",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "f1_val",
                  "data_source": "metrics",
                  "nested_key": "validation.f1_macro",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "prec_val",
                  "data_source": "metrics",
                  "nested_key": "validation.precision_macro",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "rec_val",
                  "data_source": "metrics",
                  "nested_key": "validation.recall_macro",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                },
                {
                  "name": "inlier_val",
                  "data_source": "metrics",
                  "nested_key": "one_class.inlier_rate_validation",
                  "selector": {
                    "mode": "value"
                  },
                  "value_format": ".4f"
                }
              ]
            },
            "short_description": "One-class classification performance summary with sample counts and TP/TN/FP/FN breakdown."
          },
          {
            "type": "text",
            "condition": {
              "parameter": "one_class_method",
              "operator": "==",
              "value": "simca"
            },
            "config": {
              "title": "SIMCA Settings",
              "text_template": "SIMCA Settings\n--------------\nConfidence Level:  {simca_conf}\nLimit Method:      {simca_limit}\nDecision Rule:     {simca_rule}\nCombined Metric:   {simca_combined}",
              "bindings": [
                {
                  "name": "simca_conf",
                  "data_source": "metrics",
                  "nested_key": "one_class.simca_confidence_level",
                  "value_format": ".4f",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "simca_limit",
                  "data_source": "metrics",
                  "nested_key": "one_class.simca_limit_method",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "simca_rule",
                  "data_source": "metrics",
                  "nested_key": "one_class.simca_decision_rule",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "simca_combined",
                  "data_source": "metrics",
                  "nested_key": "one_class.simca_combined_rule",
                  "selector": {
                    "mode": "value"
                  }
                }
              ]
            },
            "short_description": "SIMCA-specific model configuration."
          },
          {
            "type": "text",
            "condition": {
              "parameter": "one_class_method",
              "operator": "==",
              "value": "dd_simca"
            },
            "config": {
              "title": "DD-SIMCA Settings",
              "text_template": "DD-SIMCA Settings\n-----------------\nAlpha:             {dd_alpha}\nGamma:             {dd_gamma}\nEstimator Type:    {lim_type}",
              "bindings": [
                {
                  "name": "dd_alpha",
                  "data_source": "metrics",
                  "nested_key": "one_class.dd_simca_alpha",
                  "value_format": ".4f",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "dd_gamma",
                  "data_source": "metrics",
                  "nested_key": "one_class.dd_simca_gamma",
                  "value_format": ".4f",
                  "selector": {
                    "mode": "value"
                  }
                },
                {
                  "name": "lim_type",
                  "data_source": "model",
                  "nested_key": "simca.lim_type",
                  "selector": {
                    "mode": "value"
                  }
                }
              ]
            },
            "short_description": "DD-SIMCA-specific model configuration."
          }
        ]
      },
      {
        "title": "Confusion Matrices",
        "layout": "fd",
        "sections": [
          {
            "type": "graph",
            "config": {
              "graph_type": "heatmap",
              "title": "Calibration Confusion Matrix",
              "x_axis": {
                "data_source": "confusion_matrices",
                "nested_key": "calibration.labels",
                "label": "Predicted"
              },
              "y_axis": {
                "data_source": "confusion_matrices",
                "nested_key": "calibration.labels",
                "label": "Reference"
              },
              "z_axis": {
                "data_source": "confusion_matrices",
                "nested_key": "calibration.matrix"
              },
              "cmap": "Blues",
              "annotate_heatmap": true
