            "short_description": "Confusion matrix for cross-validation predictions (reflects training-set bias for one-class models)."
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "heatmap",
              "title": "Validation Confusion Matrix",
              "x_axis": {
                "data_source": "confusion_matrices",
                "nested_key": "validation.labels",
                "label": "Predicted"
              },
              "y_axis": {
                "data_source": "confusion_matrices",
                "nested_key": "validation.labels",
                "label": "Reference"
              },
              "z_axis": {
                "data_source": "confusion_matrices",
                "nested_key": "validation.matrix"
