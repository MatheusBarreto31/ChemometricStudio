  "short_description": "One-class classification with reference-class filtering.",
  "long_description": "Supports DD-SIMCA, SIMCA, One-Class SVM, Isolation Forest, Elliptic Envelope, and LOF (novelty). Converts inlier/outlier decisions into class predictions using Reference Class and Unknown Label. DD-SIMCA combines the Q and T² statistics into a single normalised distance criterion.",
  "execution_report_specs": {
    "messages": {},
    "warnings": {},
    "errors": {
      "classification_one_class_invalid_simca_confidence": "SIMCA confidence is invalid. Provide a finite value strictly between 0 and 1."
    }
  },
  "setup": {
    "categories": [
      "Model Parameters",
      "Data Inputs"
    ],
    "layout": [
      {
        "name": "one_class_method",
        "label": "One-Class Method",
        "category": "Model Parameters",
        "widget": "combobox",
        "type": "str",
        "default": "dd_simca",
        "values": [
          "simca",
          "dd_simca",
          "one_class_svm",
          "isolation_forest",
          "elliptic_envelope",
          "lof"
        ],
        "value_aliases": [
          "SIMCA",
          "DD-SIMCA",
          "One-Class SVM",
          "Isolation Forest",
          "Elliptic Envelope",
          "Local Outlier Factor"
        ],
        "required": true,
        "input_type": "user"
      },
      {
        "name": "one_class_reference_class",
        "label": "Reference Class",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "str",
        "default": "1",
        "required": false,
        "input_type": "user"
      },
      {
        "name": "one_class_unknown_label",
        "label": "Unknown Label",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "str",
        "default": "Other",
        "required": false,
        "input_type": "user"
      },
      {
        "name": "simca_n_components",
        "label": "SIMCA Components",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "3",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "one_class_method": [
            "simca",
            "dd_simca"
          ]
        }
      },
      {
        "name": "simca_confidence_level",
        "label": "SIMCA Confidence",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "float",
        "default": "0.95",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "one_class_method": "simca"
        }
      },
      {
        "name": "simca_limit_method",
        "label": "SIMCA Limit Method",
        "category": "Model Parameters",
        "widget": "combobox",
        "type": "str",
        "default": "analytical",
        "values": [
          "analytical",
          "empirical"
        ],
        "required": false,
        "input_type": "user",
        "visible_if": {
          "one_class_method": "simca"
        }
      },
      {
        "name": "simca_decision_rule",
        "label": "SIMCA Decision Rule",
        "category": "Model Parameters",
        "widget": "combobox",
        "type": "str",
        "default": "both",
        "values": [
          "both",
          "combined",
          "q_only",
          "t2_only"
        ],
        "required": false,
        "input_type": "user",
        "visible_if": {
          "one_class_method": "simca"
        }
      },
      {
        "name": "simca_combined_rule",
        "label": "SIMCA Combined Metric",
        "category": "Model Parameters",
        "widget": "combobox",
        "type": "str",
        "default": "l1",
        "values": [
          "l1",
          "l2"
        ],
        "value_aliases": [
          "L1: q/q_limit + t2/t2_limit",
          "L2: sqrt((q/q_limit)^2 + (t2/t2_limit)^2)"
        ],
        "required": false,
        "input_type": "user",
        "visible_if": {
          "one_class_method": "simca",
          "simca_decision_rule": "combined"
        }
      },
      {
        "name": "simca_scale_x",
        "label": "SIMCA Scale X",
        "category": "Model Parameters",
        "widget": "combobox",
        "type": "bool",
        "default": "True",
        "values": [
          true,
          false
        ],
        "value_aliases": [
          "True",
          "False"
        ],
        "required": false,
        "input_type": "user",
        "visible_if": {
