  "short_description": "Loads calibration/training and response data from files",
  "long_description": "This step loads your calibration/training dataset including data (X), response variables (Y), and optional metadata.\n\nInput Data Components:\n- X Data (Spectra): Main spectroscopic measurements (required)\n- Y Data (Responses): Target/dependent variables (optional)\n- Variable Labels: Wavelengths, frequencies, or variable names (optional)\n- Sample Labels: Sample IDs or identifiers (optional)\n\nData Formats:\n- CSV files with configurable delimiters (comma, tabs, spaces)\n- Matrix format: samples (rows) x variables (columns)\n- Vector formats for specialized data types\n- Support for multiple files via file selection\n\nConfiguration:\n- Use Auto detect for separator and data type when possible\n- Leave Header Rows empty to auto-detect how many non-data lines to skip\n- Leave Header Columns empty to auto-detect how many leading non-data columns to skip\n- Choose explicit values only when auto-detection is not appropriate\n- Transpose if needed (samples in columns instead of rows)\n\nThe loaded data becomes input for preprocessing and validation steps.",
  "setup": {
    "categories": [
      "Data Dimensionality",
      "Data Files",
      "File Format",
      "Axis Configuration",
      "Additional Options"
    ],
    "layout": [
      {
        "name": "d_specs_separator",
        "label": "Data Separator",
        "category": "File Format",
        "widget": "combobox",
        "values": [
          "Auto detect",
          "comma",
          "tabs",
          "spaces"
        ],
        "value_aliases": [
          "Auto detect",
          "Comma-separated",
          "Tab-separated",
          "Space-separated"
        ],
        "default": "Auto detect",
        "required": true,
        "input_type": "user",
        "tooltip": "Default: Auto detect. Tries comma/tab/space separators from file content."
      },
      {
        "name": "d_specs_headlines",
        "label": "Number of Header Rows",
        "category": "File Format",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": true,
        "input_type": "user",
        "tooltip": "Leave empty to auto-detect header rows. Enter a number only to force a fixed skip count."
      },
      {
        "name": "d_specs_headcolumns",
        "label": "Number of Header Columns",
        "category": "File Format",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": true,
        "input_type": "user",
        "tooltip": "Leave empty to auto-detect header columns. Enter a number only to force a fixed leading-column skip count."
      },
      {
        "name": "d_specs_type",
        "label": "Data Type",
        "category": "File Format",
        "widget": "combobox",
        "values": [
          "Auto detect",
          "x_vector",
          "xy_vector",
          "xyz_vector",
          "x_matrix",
          "xy_matrix"
        ],
        "value_aliases": [
          "Auto detect",
          "X Vector",
          "X-Y Vector",
          "X-Y-Z Vector",
          "X Matrix",
          "X-Y Matrix"
        ],
        "default": "Auto detect",
        "required": true,
        "input_type": "user",
        "tooltip": "Choose the structure that best describes your data (e.g., matrix, vector). 'Auto detect' will infer the type automatically."
      },
      {
        "name": "d_specs_dimensions",
        "label": "Data Dimensions",
        "category": "File Format",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Only required when refolding your data. Specify the size of your data in each dimension."
      },
      {
        "name": "data_path",
        "label": "X Data Files",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": true,
        "required": true,
        "input_type": "user",
        "tooltip": "Instrumental data to be used for model training/construction.",
        "ispath": true
      },
      {
        "name": "nway_flag",
        "label": "Data Order",
        "category": "Data Dimensionality",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": true,
        "input_type": "user",
        "tooltip": "Data dimensionality of each of your samples: 1 for vectors, 2 for matrices, etc."
      },
      {
        "name": "multi_file_per_sample",
        "label": "Multiple files per sample",
        "category": "Data Files",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enable when each sample consists of multiple data files (files will be divided equally among samples)",
        "visible_if": {
          "nway_flag": {
            "operator": ">=",
            "value": 3
          }
        }
      },
      {
        "name": "num_samples",
        "label": "Number of Samples",
        "category": "Data Files",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": false,
        "input_type": "user",
        "tooltip": "Number of samples (files will be divided equally into groups)",
        "visible_if": {
          "multi_file_per_sample": true
        }
      },
      {
        "name": "s_padding_type",
        "label": "Sample Padding Type",
        "category": "Additional Options",
        "widget": "combobox",
        "values": [
          "NaN",
          "Zeroes"
        ],
        "default": "NaN",
        "required": false,
        "input_type": "user",
        "tooltip": "Padding value used when samples have different sizes.",
        "visible_if": {
          "nway_flag": {
            "operator": ">=",
            "value": 2
          }
        }
      },
      {
        "name": "y_path",
        "label": "Y Data File",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Response variable(s) file. It can contain multiple columns and headers (mark Y Labels from File if using headers).",
        "ispath": true,
        "visible_if": {
          "y_from_x": false
        }
      },
      {
        "name": "y_columns",
        "label": "Y Columns",
        "category": "Data Files",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Columns of the X file to use as Y data (1-based). Supports single values (3), comma/space lists (1,3,5), ranges (1:4 or 1-4), and stepped ranges (2:2:6).",
        "visible_if": {
          "y_from_x": true
        }
      },
      {
        "name": "y_labels_from_file",
        "label": "Y Labels from File",
        "category": "Data Files",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "If enabled, the first row of the Y file is used as Y-column labels and excluded from Y numeric data.",
        "visible_if": {
          "y_from_x": false
        }
      },
      {
        "name": "y_labels",
        "label": "Y Labels",
        "category": "Data Files",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Manual labels for Y columns, separated by comma, tab, or spaces.",
        "visible_if": {
          "y_labels_from_file": false
        }
      },
      {
        "name": "cdata_path",
        "label": "Classification Data File",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": false,
        "required": false,
        "input_type": "user",
        "tooltip": "File containing class information. It can support multiple class layers by using separate columns for each layer.",
        "ispath": true,
        "visible_if": {
          "class_from_x": false
        }
      },
      {
        "name": "class_columns",
        "label": "Class Columns",
        "category": "Data Files",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Columns of the X file to use as class labels (1-based). Supports single values (3), comma/space lists (1,3,5), ranges (1:4 or 1-4), and stepped ranges (2:2:6). String labels are preserved.",
        "visible_if": {
          "class_from_x": true
        }
      },
      {
        "name": "smp_path",
        "label": "Sample Labels",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Labels for samples (e.g., sample IDs)",
        "ispath": true,
        "visible_if": {
          "smp_from_x": false
        }
      },
      {
        "name": "smp_column",
        "label": "Sample Label Column",
        "category": "Data Files",
        "widget": "entry",
        "type": "int",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Single column number (1-based) whose values become sample labels.",
        "visible_if": {
          "smp_from_x": true
        }
      },
      {
        "name": "y_from_x",
        "label": "Y from X File",
        "category": "Data Files",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Extract Y data from columns in the X file instead of loading a separate Y file. Only available for X Matrix data type.",
        "visible_if": {
          "d_specs_type": ["Auto detect", "x_matrix"]
        }
      },
      {
        "name": "class_from_x",
        "label": "Class from X File",
        "category": "Data Files",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Extract class labels from columns in the X file instead of loading a separate classification file. Only available for X Matrix data type.",
        "visible_if": {
          "d_specs_type": ["Auto detect", "x_matrix"]
        }
      },
      {
        "name": "smp_from_x",
        "label": "Sample Labels from X File",
        "category": "Data Files",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Extract sample labels from a single column in the X file instead of loading a separate labels file. Only available for X Matrix data type.",
        "visible_if": {
          "d_specs_type": ["Auto detect", "x_matrix"]
        }
      },
      {
        "name": "var_path",
        "label": "Axis Labels Files",
        "category": "Axis Configuration",
        "widget": "file_selector_list",
        "count_source": "nway_flag",
        "required": false,
        "input_type": "user",
        "tooltip": "Files containing axis labels for each dimension (one file per dimension, based on Data Order)",
        "ispath": true
      },
      {
        "name": "dim_labels",
        "label": "Axis Titles",
        "category": "Axis Configuration",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Name for each dimension. Empty values will use position index."
      },
      {
        "name": "axis_nature",
        "label": "Axis Nature",
        "category": "Axis Configuration",
        "widget": "combobox_list",
        "count_source": "nway_flag",
        "values": [
          "Continuous",
          "Discrete"
        ],
        "value_aliases": [
          "Continuous",
          "Discrete"
        ],
        "default": "Continuous",
        "required": false,
        "input_type": "user",
        "tooltip": "Nature for each axis (one per dimension). Use Continuous for numerical scales and Discrete for categorical/indexed axes."
      },
      {
        "name": "scale_type",
        "label": "Scale Type",
        "category": "Axis Configuration",
        "widget": "combobox_list",
        "count_source": "nway_flag",
        "values": [
          "Linear",
          "Log10",
          "Log2",
          "Ln"
        ],
        "default": "Linear",
        "required": false,
        "input_type": "user",
        "tooltip": "Scale type for generating axis vectors from start/end points (one per dimension)"
      },
      {
        "name": "transpose",
        "label": "Transpose Data",
        "category": "Additional Options",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Transposes data"
      },
      {
        "name": "reshape_order",
        "label": "Reshape Order",
        "category": "Additional Options",
        "widget": "combobox",
        "values": [
          "F",
          "C"
        ],
        "value_aliases": [
          "Fortran/MATLAB",
          "C/NumPy"
        ],
        "default": "F",
        "required": false,
        "input_type": "user",
        "tooltip": "Order for reshaping multiway data: Fortran (F) for MATLAB compatibility, C for NumPy default"
      },
      {
        "name": "axis_info",
        "label": "Axis Generation Info",
        "category": "Axis Configuration",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Axis range for each dimension as 'start end' (e.g., '100 200'). One entry per dimension."
      }
    ]
  },
  "analysis": {
    "pages": [
      {
        "title": "Data Overview",
        "layout": "ed",
        "condition": {
          "parameter": "nway_flag",
          "operator": "==",
          "value": "1"
        },
        "sections": [
          {
            "type": "table",
            "config": {
              "data_source": "X_cal",
              "decimal_places": 4,
              "max_rows": 200,
              "max_cols": 200,
              "title": "X Data"
            },
            "short_description": "Displays X Data as a table in the analysis section.",
            "long_description": "This section presents 'X Data' in tabular form. Use this view to review numeric values, compare rows/columns, and inspect detailed outputs for this section."
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
