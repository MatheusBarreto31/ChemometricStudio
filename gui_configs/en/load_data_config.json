  "short_description": "Loads spectroscopic and response data from files",
  "long_description": "This step loads your calibration dataset including spectroscopic data (X), response variables (Y), and optional metadata.\n\nInput Data Components:\n- X Data (Spectra): Main spectroscopic measurements (required)\n- Y Data (Responses): Target/dependent variables (optional)\n- Variable Labels: Wavelengths, frequencies, or variable names (optional)\n- Sample Labels: Sample IDs or identifiers (optional)\n\nData Formats:\n- CSV files with configurable delimiters (comma, tabs, spaces)\n- Matrix format: samples (rows) x variables (columns)\n- Vector formats for specialized data types\n- Support for multiple files via file selection\n\nConfiguration:\n- Specify delimiter type for your files\n- Set number of header rows to skip\n- Choose appropriate data type structure\n- Transpose if needed (samples in columns instead of rows)\n\nThe loaded data becomes input for preprocessing and validation steps.",
  "setup": {
    "categories": [
      "Data Dimensionality",
      "Data Files",
      "File Format",
      "Axis Configuration",
      "Additional Options"
    ],
    "layout": [
      {
        "name": "d_specs_separator",
        "label": "Data Separator",
        "category": "File Format",
        "widget": "combobox",
        "values": [
          "comma",
          "tabs",
          "spaces"
        ],
        "value_aliases": [
          "Comma-separated",
          "Tab-separated",
          "Space-separated"
        ],
        "default": "comma",
        "required": true,
        "input_type": "user",
        "tooltip": "Delimiter used in data files"
      },
      {
        "name": "d_specs_headlines",
        "label": "Number of Header Rows",
        "category": "File Format",
        "widget": "entry",
        "type": "int",
        "default": "0",
        "required": true,
        "input_type": "user",
        "tooltip": "Number of rows to skip at the beginning of each file"
      },
      {
        "name": "d_specs_type",
        "label": "Data Type",
        "category": "File Format",
        "widget": "combobox",
        "values": [
          "x_vector",
          "xy_vector",
          "xyz_vector",
          "x_matrix",
          "xy_matrix"
        ],
        "value_aliases": [
          "X Vector",
          "X-Y Vector",
          "X-Y-Z Vector",
          "X Matrix",
          "X-Y Matrix"
        ],
        "default": "x_matrix",
        "required": true,
        "input_type": "user",
        "tooltip": "Structure of data: matrix (samples × variables) or vector formats"
      },
      {
        "name": "d_specs_dimensions",
        "label": "Data Dimensions",
        "category": "File Format",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Dimension size for each axis (numeric values, one per dimension)"
      },
      {
        "name": "data_path",
        "label": "X Data Files",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": true,
        "required": true,
        "input_type": "user",
        "tooltip": "Spectroscopic data files (spectra/X data)",
        "ispath": true
      },
      {
        "name": "nway_flag",
        "label": "Data Order",
        "category": "Data Dimensionality",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": true,
        "input_type": "user",
        "tooltip": "1 for 2D data, >1 for multiway data"
      },
      {
        "name": "multi_file_per_sample",
        "label": "Multiple files per sample",
        "category": "Data Files",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Enable when each sample consists of multiple data files (files will be divided equally among samples)",
        "visible_if": {
          "nway_flag": {
            "operator": ">=",
            "value": 3
          }
        }
      },
      {
        "name": "num_samples",
        "label": "Number of Samples",
        "category": "Data Files",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": false,
        "input_type": "user",
        "tooltip": "Number of samples (files will be divided equally into groups)",
        "visible_if": {
          "multi_file_per_sample": true
        }
      },
      {
        "name": "y_path",
        "label": "Y Data File",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Response variable(s) file",
        "ispath": true
      },
      {
        "name": "cdata_path",
        "label": "Classification Data File",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Classification data file (one class label per line)",
        "ispath": true
      },
      {
        "name": "var_path",
        "label": "Axis Labels Files",
        "category": "Axis Configuration",
        "widget": "file_selector_list",
        "count_source": "nway_flag",
        "required": false,
        "input_type": "user",
        "tooltip": "Files containing axis labels for each dimension (one file per dimension, based on Data Order)",
        "ispath": true
      },
      {
        "name": "smp_path",
        "label": "Sample Labels",
        "category": "Data Files",
        "widget": "file_selector",
        "multiple": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Labels for samples (e.g., sample IDs)",
        "ispath": true
      },
      {
        "name": "dim_labels",
        "label": "Axis Titles",
        "category": "Axis Configuration",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Name for each dimension. Empty values will use position index."
      },
      {
        "name": "scale_type",
        "label": "Scale Type",
        "category": "Axis Configuration",
        "widget": "combobox_list",
        "count_source": "nway_flag",
        "values": [
          "Linear",
          "Log10",
          "Log2",
          "Ln"
        ],
        "default": "Linear",
        "required": false,
        "input_type": "user",
        "tooltip": "Scale type for generating axis vectors from start/end points (one per dimension)"
      },
      {
        "name": "transpose",
        "label": "Transpose Data",
        "category": "Additional Options",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Transposes data"
      },
      {
        "name": "reshape_order",
        "label": "Reshape Order",
        "category": "Additional Options",
        "widget": "combobox",
        "values": [
          "F",
          "C"
        ],
        "value_aliases": [
          "Fortran/MATLAB",
          "C/NumPy"
        ],
        "default": "F",
        "required": false,
        "input_type": "user",
        "tooltip": "Order for reshaping multiway data: Fortran (F) for MATLAB compatibility, C for NumPy default"
      },
      {
        "name": "axis_info",
        "label": "Axis Generation Info",
        "category": "Axis Configuration",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Axis range for each dimension as 'start end' (e.g., '100 200'). One entry per dimension."
      }
    ]
  },
  "analysis": {
    "pages": [
      {
        "title": "Data Overview",
        "layout": "ed",
