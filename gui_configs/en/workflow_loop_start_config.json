        "type": "list",
        "default": [],
        "required": false,
        "input_type": "user",
        "visible_if": {"mode": ["sweep_choice"]},
        "tooltip": "Select one or more choice values to include in sweep. For boolean targets, defaults to Off then On."
      },
      {
        "name": "benchmark_source",
        "label": "Benchmark Source (instance.output)",
        "category": "Loop",
        "widget": "combobox",
        "editable": false,
        "values": [],
        "value_aliases": [],
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Example: pca_analysis.metrics"
      },
      {
        "name": "benchmark_nested_key",
        "label": "Benchmark Nested Key (for dict outputs)",
        "category": "Loop",
        "widget": "combobox",
        "editable": true,
        "values": [],
        "value_aliases": [],
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Optional nested key path for dict benchmark outputs (e.g., rmse or scores.mean)."
      },
      {
        "name": "benchmark_mode",
        "label": "Benchmark Mode",
        "category": "Loop",
        "widget": "combobox",
        "values": ["min", "max"],
        "value_aliases": ["Min", "Max"],
        "default": "min",
        "required": false,
        "input_type": "user",
        "tooltip": "Choose lower-is-better (min) or higher-is-better (max)"
      },
      {
        "name": "use_best_iteration",
        "label": "Keep Best Iteration Outputs",
        "category": "Loop",
        "widget": "checkbutton",
