        "default": "repeat",
        "required": true,
        "input_type": "user",
        "tooltip": "repeat/feedback rerun body; sweep modes update one parameter each iteration"
      },
      {
        "name": "sweep_target",
        "label": "Sweep Target (instance.param)",
        "category": "Loop",
        "widget": "combobox",
        "editable": false,
        "values": [],
        "value_aliases": [],
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {"mode": ["sweep_numeric", "sweep_choice"]},
        "tooltip": "Example: smoothing.window_size"
      },
      {
        "name": "sweep_values",
        "label": "Sweep Values",
        "category": "Loop",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {"mode": ["sweep_numeric"]},
        "tooltip": "Numeric: 0:2:6, 0:3, 0-3, or comma list."
