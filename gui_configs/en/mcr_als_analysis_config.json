{
  "display_name": "MCR-ALS Analysis",
  "category": "4.Exploratory Analysis",
  "data_type": "multiway",
  "input_aliases": {
    "X_cal": "X Calibration",
    "Y_cal": "Y Calibration",
    "X_val": "X Validation",
    "Y_val": "Y Validation",
    "n_components": "Components",
    "nway_flag": "Data Order",
    "aug_direction": "Augmented Direction",
    "max_iter": "Max Iterations",
    "tol": "Tolerance",
    "random_state": "Random Seed",
    "constraint_non_negative": "Non-negative Constraint",
    "constraint_non_negative_mode_c": "Non-negative Mode (C)",
    "constraint_non_negative_mode_st": "Non-negative Mode (S)",
    "constraint_cumsum_non_negative": "Cumsum Non-negative Constraint",
    "constraint_zero_end_points": "Zero End Points Constraint",
    "constraint_zero_cumsum_end_points": "Zero Cumsum End Points Constraint",
    "constraint_normalize": "Normalize Constraint",
    "constraint_cut_below": "Cut Below Constraint",
    "constraint_cut_above": "Cut Above Constraint",
    "constraint_compress_below": "Compress Below Constraint",
    "constraint_compress_above": "Compress Above Constraint",
    "constraint_replace_zeros": "Replace Zeros Constraint",
    "constraint_planarize": "Planarize Constraint",
    "constraint_zero_end_points_span": "Zero End Points Span",
    "constraint_zero_cumsum_nodes": "Zero Cumsum Nodes",
    "constraint_cut_below_value": "Cut Below Value",
    "constraint_cut_above_value": "Cut Above Value",
    "constraint_compress_below_value": "Compress Below Value",
    "constraint_compress_above_value": "Compress Above Value",
    "constraint_replace_zeros_feature": "Replace Zeros Feature",
    "constraint_replace_zeros_fval": "Replace Zeros F-Value",
    "constraint_planarize_targets_c": "Planarize Targets (C)",
    "constraint_planarize_targets_st": "Planarize Targets (S)",
    "constraint_planarize_shape_c": "Planarize Shape (C)",
    "constraint_planarize_shape_st": "Planarize Shape (S)",
    "constraint_planarize_use_vals_above": "Planarize Use Values Above",
    "constraint_planarize_use_vals_below": "Planarize Use Values Below",
    "constraint_planarize_lims_to_plane": "Planarize Limit To Plane",
    "constraint_planarize_scaler": "Planarize Scaler",
    "constraint_planarize_recalc_scaler": "Planarize Recalculate Scaler",
    "sweep_mode": "Sweep Mode",
    "component_range": "Component Range",
    "component_y_mapping": "Component-Y Mapping",
    "cv_config": "CV Configuration",
    "y_labels": "Y Labels"
  },
  "output_aliases": {
    "scores_mode_a": "Concentration Scores (C)",
    "val_scores_mode_a": "Validation Concentration Scores",
    "concentrations_unfolded": "Unfolded Concentration Profiles",
    "concentration_row_axis": "Unfolded Row Axis",
    "s_axis_vector": "S Axis Vector",
    "sample_boundary_positions": "Sample Boundary Positions",
    "cal_val_boundary_position": "Calibration/Validation Boundary",
    "components": "Spectral Components (S)",
    "reconstructed": "Reconstructed Data",
    "residual": "Residual Data",
    "metrics": "Metrics",
    "calibration_models": "Calibration Models",
    "component_y_mapping": "Component-Y Pairing",
    "mcr_als_report": "MCR-ALS Report",
    "cv_results": "CV Results",
    "y_cv_pred": "CV Predictions",
    "sweep_n_iter": "Sweep Iterations"
  },
  "short_description": "MCR-ALS (pyMCR) decomposition with optional calibration, sweep, and cross-validation.",
  "long_description": "Fits MCR-ALS to unfolded calibration data using pyMCR, estimates concentration/spectral profiles, and optionally maps components to Y targets for calibration and validation prediction.",
  "setup": {
    "categories": [
      "Model Parameters",
      "Constraints",
      "Calibration",
      "Cross-Validation",
      "Data Inputs"
    ],
    "layout": [
      {
        "name": "n_components",
        "label": "Number of Components",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "2",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "max_iter",
        "label": "Maximum Iterations",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "250",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "tol",
        "label": "Tolerance",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "float",
        "default": "1e-8",
        "required": true,
        "input_type": "user"
      },
      {
        "name": "random_state",
        "label": "Random Seed",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "str",
        "default": "42",
        "required": false,
        "input_type": "user"
      },
      {
        "name": "constraint_non_negative",
        "label": "Non-negative",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": true,
        "required": false,
        "input_type": "user",
        "tooltip": "Enable non-negativity for C and/or S."
      },
      {
        "name": "constraint_non_negative_mode_c",
        "label": "Non-negative Mode (C)",
        "category": "Constraints",
        "widget": "combobox",
        "values": ["NNLS", "PROJECT", "NNLS_PROJECT"],
        "value_aliases": ["NNLS", "Project", "NNLS + Project"],
        "default": "NNLS",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_non_negative": {
            "operator": "index_true",
            "index": 0
          }
        },
        "tooltip": "C mode: NNLS uses non-negative solver; Project applies non-negative projection after solve; NNLS + Project does both."
      },
      {
        "name": "constraint_non_negative_mode_st",
        "label": "Non-negative Mode (S)",
        "category": "Constraints",
        "widget": "combobox",
        "values": ["NNLS", "PROJECT", "NNLS_PROJECT"],
        "value_aliases": ["NNLS", "Project", "NNLS + Project"],
        "default": "NNLS",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_non_negative": {
            "operator": "index_true",
            "index": 1
          }
        },
        "tooltip": "S mode: NNLS uses non-negative solver; Project applies non-negative projection after solve; NNLS + Project does both."
      },
      {
        "name": "constraint_cumsum_non_negative",
        "label": "Cumsum Non-negative",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Apply cumulative-sum non-negativity along each profile vector."
      },
      {
        "name": "constraint_zero_end_points",
        "label": "Zero End Points",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Force profile endpoints toward zero by baseline subtraction."
      },
      {
        "name": "constraint_zero_end_points_span",
        "label": "Zero End Points Span",
        "category": "Constraints",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": false,
        "input_type": "user",
        "tooltip": "Number of points averaged at each edge for zero-end correction.",
        "visible_if": {
          "constraint_zero_end_points": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_zero_cumsum_end_points",
        "label": "Zero Cumsum End Points",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Center cumulative-sum segments to near zero, optionally using node boundaries."
      },
      {
        "name": "constraint_zero_cumsum_nodes",
        "label": "Zero Cumsum Nodes",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_zero_cumsum_end_points": {
            "operator": "any_true"
          }
        },
        "tooltip": "Optional 1-based node indices, e.g. 3,7,10"
      },
      {
        "name": "constraint_normalize",
        "label": "Normalize",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "ConstraintNorm in pyMCR."
      },
      {
        "name": "constraint_cut_below",
        "label": "Cut Below",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Set values below threshold to zero."
      },
      {
        "name": "constraint_cut_below_value",
        "label": "Cut Below Value",
        "category": "Constraints",
        "widget": "entry",
        "type": "float",
        "default": "0.0",
        "required": false,
        "input_type": "user",
        "tooltip": "Threshold used by Cut Below.",
        "visible_if": {
          "constraint_cut_below": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_cut_above",
        "label": "Cut Above",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Set values above threshold to zero."
      },
      {
        "name": "constraint_cut_above_value",
        "label": "Cut Above Value",
        "category": "Constraints",
        "widget": "entry",
        "type": "float",
        "default": "1.0",
        "required": false,
        "input_type": "user",
        "tooltip": "Threshold used by Cut Above.",
        "visible_if": {
          "constraint_cut_above": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_compress_below",
        "label": "Compress Below",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Clamp values below threshold up to the threshold value."
      },
      {
        "name": "constraint_compress_below_value",
        "label": "Compress Below Value",
        "category": "Constraints",
        "widget": "entry",
        "type": "float",
        "default": "0.0",
        "required": false,
        "input_type": "user",
        "tooltip": "Threshold used by Compress Below.",
        "visible_if": {
          "constraint_compress_below": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_compress_above",
        "label": "Compress Above",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Clamp values above threshold down to the threshold value."
      },
      {
        "name": "constraint_compress_above_value",
        "label": "Compress Above Value",
        "category": "Constraints",
        "widget": "entry",
        "type": "float",
        "default": "1.0",
        "required": false,
        "input_type": "user",
        "tooltip": "Threshold used by Compress Above.",
        "visible_if": {
          "constraint_compress_above": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_replace_zeros",
        "label": "Replace Zeros",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Replace zero-sum rows with a fallback one-hot profile."
      },
      {
        "name": "constraint_replace_zeros_feature",
        "label": "Replace Zeros Feature",
        "category": "Constraints",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_replace_zeros": {
            "operator": "any_true"
          }
        },
        "tooltip": "1-based feature index used by ConstraintReplaceZeros."
      },
      {
        "name": "constraint_replace_zeros_fval",
        "label": "Replace Zeros F-Value",
        "category": "Constraints",
        "widget": "entry",
        "type": "float",
        "default": "1.0",
        "required": false,
        "input_type": "user",
        "tooltip": "Total magnitude assigned to replacement rows.",
        "visible_if": {
          "constraint_replace_zeros": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_planarize",
        "label": "Planarize",
        "category": "Constraints",
        "widget": "checkbutton_list",
        "count_source": "2",
        "item_labels": ["C", "S"],
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Fit selected columns to a smooth plane over a 2D reshaped grid."
      },
      {
        "name": "constraint_planarize_targets_c",
        "label": "Planarize Targets (C)",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_planarize": {
            "operator": "index_true",
            "index": 0
          }
        },
        "tooltip": "Optional 1-based column indices for C planarization."
      },
      {
        "name": "constraint_planarize_shape_c",
        "label": "Planarize Shape (C)",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_planarize": {
            "operator": "index_true",
            "index": 0
          }
        },
        "tooltip": "rows,cols where rows*cols equals number of C rows in fit matrix."
      },
      {
        "name": "constraint_planarize_targets_st",
        "label": "Planarize Targets (S)",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_planarize": {
            "operator": "index_true",
            "index": 1
          }
        },
        "tooltip": "Optional 1-based column indices for S planarization."
      },
      {
        "name": "constraint_planarize_shape_st",
        "label": "Planarize Shape (S)",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "constraint_planarize": {
            "operator": "index_true",
            "index": 1
          }
        },
        "tooltip": "rows,cols where rows*cols equals number of S rows (components)."
      },
      {
        "name": "constraint_planarize_use_vals_above",
        "label": "Planarize Use Values Above",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Optional lower bound filter when fitting the plane.",
        "visible_if": {
          "constraint_planarize": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_planarize_use_vals_below",
        "label": "Planarize Use Values Below",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Optional upper bound filter when fitting the plane.",
        "visible_if": {
          "constraint_planarize": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_planarize_lims_to_plane",
        "label": "Planarize Limit To Plane",
        "category": "Constraints",
        "widget": "checkbutton",
        "default": true,
        "required": false,
        "input_type": "user",
        "tooltip": "Limit planarized values to optional above/below bounds.",
        "visible_if": {
          "constraint_planarize": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_planarize_scaler",
        "label": "Planarize Scaler",
        "category": "Constraints",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Optional explicit scaler used for planar fit coordinate magnitudes.",
        "visible_if": {
          "constraint_planarize": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "constraint_planarize_recalc_scaler",
        "label": "Planarize Recalculate Scaler",
        "category": "Constraints",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user",
        "tooltip": "Recompute planarization scaler for each call instead of reusing it.",
        "visible_if": {
          "constraint_planarize": {
            "operator": "any_true"
          }
        }
      },
      {
        "name": "sweep_mode",
        "label": "Sweep Components",
        "category": "Model Parameters",
        "widget": "checkbutton",
        "default": false,
        "required": false,
        "input_type": "user"
      },
      {
        "name": "component_range",
        "label": "Component Range",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "sweep_mode": true
        },
        "tooltip": "Examples: 2:6, 2-8, 2,3,4"
      },
      {
        "name": "aug_direction",
        "label": "Augmented Direction",
        "category": "Model Parameters",
        "widget": "entry",
        "type": "int",
        "default": "1",
        "required": false,
        "input_type": "user",
        "visible_if": {
          "nway_flag": {
            "operator": ">=",
            "value": 2
          }
        },
        "tooltip": "Direction index (1-based) used as augmented row axis for multiway MCR-ALS unfolding."
      },
      {
        "name": "component_y_mapping",
        "label": "Component-Y Mapping",
        "category": "Calibration",
        "widget": "entry_list",
        "count_source": "n_components",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "One entry per component: Y column index (1-based). Empty entry excludes that component. If all are empty, all valid component-to-Y combinations are evaluated automatically."
      },
      {
        "name": "y_labels",
        "label": "Y Labels",
        "category": "Calibration",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "router",
        "visible_if": false,
        "tooltip": "Routed from upstream labels source; hidden in direct user setup."
      },
      {
        "name": "cv_config",
        "label": "Cross-Validation Config",
        "category": "Cross-Validation",
        "widget": "entry",
        "type": "CVConfig",
        "default": "",
        "required": false,
        "input_type": "router",
        "visible_if": false,
        "tooltip": "Routed from CV configuration step; hidden in direct user setup."
      },
      {
        "name": "nway_flag",
        "label": "Data Order",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": false,
        "visible_if": {
          "input_type": "user"
        },
        "input_type": "inherited"
      }
    ]
  },
  "analysis": {
    "pages": [
      {
        "title": "MCR-ALS Deconvolution Report",
        "layout": "fp",
        "sections": [
          {
            "type": "text",
            "config": {
              "title": "MCR-ALS Text Report",
              "text_template": "{report_text}",
              "bindings": [
                {
                  "name": "report_text",
                  "data_source": "mcr_als_report",
                  "selector": {
                    "mode": "value"
                  }
                }
              ]
            }
          }
        ]
      },
      {
        "title": "Prediction Tables",
        "layout": "ew",
        "condition": {
          "parameter": "y_cal_true",
          "operator": "exists",
          "value": true
        },
        "sections": [
          {
            "type": "table",
            "config": {
              "title": "Calibration Predictions, References, and Error",
              "row_label": "Sample",
              "row_headers": "smp_cal",
              "columns": [
                {
                  "data_source": "y_cal_pred_pairs",
                  "name": "Predicted"
                },
                {
                  "data_source": "y_cv_pred_pairs",
                  "name": "Predicted (CV)"
                },
                {
                  "data_source": "y_cal_true_pairs",
                  "name": "Reference"
                },
                {
                  "data_source": "y_cal_error_pairs",
                  "name": "Error"
                },
                {
                  "data_source": "y_cv_error_pairs",
                  "name": "Error (CV)"
                }
              ],
              "data_slicing": [
                {
                  "name": "Pairing",
                  "dimension": 1,
                  "default": 0,
                  "show_navigation_menu": true
                }
              ],
              "variable_labels": "mcr_pairing_labels_by_dimension",
              "pairing_labels_source": "mcr_pairing_labels",
              "slice_title_source": "mcr_pair_y_titles",
              "slice_title_dimension": 1,
              "slice_title_prefix": "Y",
              "decimal_places": 6,
              "max_rows": 500
            }
          },
          {
            "type": "table",
            "config": {
              "title": "Validation Predictions, References, and Error",
              "row_label": "Sample",
              "row_headers": "smp_val",
              "columns": [
                {
                  "data_source": "y_val_pred_pairs",
                  "name": "Predicted"
                },
                {
                  "data_source": "y_val_true_pairs",
                  "name": "Reference"
                },
                {
                  "data_source": "y_val_error_pairs",
                  "name": "Error"
                }
              ],
              "data_slicing": [
                {
                  "name": "Pairing",
                  "dimension": 1,
                  "default": 0,
                  "show_navigation_menu": true
                }
              ],
              "variable_labels": "mcr_pairing_labels_by_dimension",
              "pairing_labels_source": "mcr_pairing_labels",
              "slice_title_source": "mcr_pair_y_titles",
              "slice_title_dimension": 1,
              "slice_title_prefix": "Y",
              "decimal_places": 6,
              "max_rows": 500
            }
          }
        ]
      },
      {
        "title": "Sweep Scree",
        "layout": "fd",
        "condition": {
          "parameter": "sweep_mode",
          "operator": "==",
          "value": "True"
        },
        "sections": [
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "marker": "o",
              "x_axis": {
                "data_source": "sweep_F",
                "force_integer": true,
                "label": "F"
              },
              "y_axis": {
                "data_source": "sweep_sfit",
                "label": "sfit"
              },
              "title": "Sweep: sfit vs F",
              "show_origin": false
            }
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "marker": "o",
              "x_axis": {
                "data_source": "sweep_F",
                "force_integer": true,
                "label": "F"
              },
              "y_axis": {
