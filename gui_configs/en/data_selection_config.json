  "short_description": "Selects or removes samples and variables from calibration/validation datasets",
  "long_description": "This step filters loaded data by samples and variables. Selection entries accept either numeric specs or text labels. Numeric specs support values, ranges, and stepped ranges such as '1:10', '200-250.5', and '15,6,28,60:2:90,1-10,91-5-101'. Text selectors support comma, tab, or semicolon separators.",
  "setup": {
    "categories": [
      "Data Inputs",
      "Sample Selection",
      "Variable Selection"
    ],
    "layout": [
      {
        "name": "nway_flag",
        "label": "Data Dimensionality",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": true,
        "input_type": "inherited",
        "tooltip": "Routed from upstream data loading step"
      },
      {
        "name": "X_cal",
        "label": "X Calibration Data",
        "category": "Data Inputs",
        "widget": "data_input",
        "required": true,
        "input_type": "routed",
        "tooltip": "Routed calibration tensor/matrix"
      },
      {
