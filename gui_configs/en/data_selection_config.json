        "required": false,
        "input_type": "inherited",
        "tooltip": "Optional labels used to name variable-selection directions"
      },
      {
        "name": "sample_mode_cal",
        "label": "Calibration/Training Selection Mode",
        "category": "Sample Selection",
        "widget": "combobox",
        "values": [
          "Select",
          "Remove"
        ],
        "default": "Remove",
        "required": true,
        "input_type": "user",
        "tooltip": "Select: keep specified samples. Remove: drop specified samples."
      },
      {
        "name": "sample_values_cal",
        "label": "Calibration/Training Samples",
        "category": "Sample Selection",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Numeric or text selector list. Numeric accepts values/ranges/steps. Text supports comma, tab, or semicolon separators."
      },
      {
        "name": "sample_mode_val",
        "label": "Validation/Test Selection Mode",
        "category": "Sample Selection",
        "widget": "combobox",
        "values": [
          "Select",
          "Remove"
        ],
        "default": "Remove",
        "required": true,
        "input_type": "user",
        "tooltip": "Select: keep specified samples. Remove: drop specified samples."
      },
      {
        "name": "sample_values_val",
        "label": "Validation/Test Samples",
        "category": "Sample Selection",
        "widget": "entry",
        "type": "str",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "Numeric or text selector list. Numeric accepts values/ranges/steps. Text supports comma, tab, or semicolon separators."
      },
      {
        "name": "variable_modes",
        "label": "Variable Selection Mode",
        "category": "Variable Selection",
        "widget": "combobox_list",
        "count_source": "nway_flag",
        "item_labels_source": "dim_labels",
        "item_label_prefix": "Dimension",
        "values": [
          "Select",
          "Remove"
        ],
        "default": "Remove",
        "required": true,
        "input_type": "user",
        "tooltip": "One mode per non-sample dimension."
      },
      {
        "name": "variable_values",
        "label": "Variables",
        "category": "Variable Selection",
        "widget": "entry_list",
        "count_source": "nway_flag",
        "item_labels_source": "dim_labels",
        "item_label_prefix": "Dimension",
        "default": "",
        "required": false,
        "input_type": "user",
        "tooltip": "One selector per non-sample dimension. Numeric compares against axis_n_info (or position index); text compares against axis_t_info."
      }
    ]
  },
  "analysis": {
    "pages": [
      {
        "title": "Data Overview (Calibration)",
        "layout": "ew",
        "condition": {
          "parameter": "nway_flag",
          "operator": "==",
          "value": "1"
        },
        "sections": [
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "x_axis": {
                "data_source": "in.axis_n_info",
                "index": 1,
                "label": "dim_labels",
                "l_index": 1
              },
              "y_axis": {
                "data_source": "in.X_cal",
                "label": "Signal"
              },
              "class_labels": "in.class_data_cal",
              "title": "Spectral Data (Original)",
              "dimension_labels": "dim_labels",
              "variable_labels": "in.axis_t_info"
            },
            "short_description": "Displays all spectra coloured by class as a line graph in the analysis section.",
            "long_description": "This section visualizes all loaded spectra simultaneously. Lines are coloured by class value using the selected colormap settings. Class data must be loaded for class-driven styling to appear."
          },
          {
            "type": "graph",
            "config": {
              "graph_type": "line",
              "x_axis": {
                "data_source": "axis_n_info",
                "index": 1,
                "label": "dim_labels",
                "l_index": 1
